{
  "name": "cube-bounce-vr",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/server && npm run build --workspace=packages/client",
    "start": "node packages/server/dist/index.js",
    "client" : "npm run dev --workspace=packages/client",
    "server": "npm run dev --workspace=packages/server"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}